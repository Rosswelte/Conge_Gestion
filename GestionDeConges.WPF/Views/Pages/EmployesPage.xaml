<UserControl x:Class="GestionDeConges.WPF.Views.Pages.EmployesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:GestionDeConges.WPF.Converters"
             Background="{StaticResource BgPageBrush}">


    <DockPanel Margin="24">

        <!-- En-tête -->
        <StackPanel DockPanel.Dock="Top" Margin="0 0 0 16">
            <TextBlock Text="👥 Gestion des employés"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>

            <Grid Margin="0 12 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         materialDesign:HintAssist.Hint="🔍  Rechercher par nom, prénom ou email…"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Text="{Binding FiltreRecherche, UpdateSourceTrigger=PropertyChanged}"
                         MaxWidth="400" HorizontalAlignment="Left"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="➕ Nouvel employé"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="40" Padding="12 0" Margin="0 0 8 0"
                            Click="BtnAjouterEmploye_Click"/>
                    <ToggleButton Content="🗂  Afficher supprimés"
                                  IsChecked="{Binding AfficherHistorique}"
                                  Style="{StaticResource MaterialDesignOutlinedButton}"
                                  Margin="0 0 8 0" Padding="12 0" Height="40"
                                  Foreground="{StaticResource PrimaryBrush}"
                                  BorderBrush="{StaticResource PrimaryBrush}"/>
                    <Button Content="🔄  Actualiser"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="40" Padding="12 0"
                            Command="{Binding ChargerCommand}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Spinner -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True" Height="4" Margin="0 0 0 8"
                     Visibility="{Binding IsBusy,
                         Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Message d'erreur -->
        <Border DockPanel.Dock="Top"
                Background="#FCEBEB" CornerRadius="6" Padding="12 8" Margin="0 0 0 12"
                Visibility="{Binding Erreur,
                    Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding Erreur}" Foreground="#501313"/>
        </Border>

        <!-- Liste employés actifs -->
        <Border Background="White" CornerRadius="10" Padding="16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background"    Value="White"/>
                    <Setter Property="CornerRadius"  Value="10"/>
                    <Setter Property="Padding"       Value="16"/>
                    <Setter Property="Visibility"    Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AfficherHistorique}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Employés actifs"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0 0 0 12"/>

                <DataGrid ItemsSource="{Binding Employes}"
                          SelectedItem="{Binding EmployeSelectionne}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="100"/>
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="100"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="110"/>
                        <DataGridTextColumn Header="Poste" Binding="{Binding Poste.Nom}" Width="120"/>
                        <DataGridTextColumn Header="Département" Binding="{Binding Poste.Departement.Nom}" Width="120"/>
                        <DataGridTextColumn Header="Embauché le"
                            Binding="{Binding DateEmbauche, Converter={StaticResource DateOnlyToStringConverter}}"
                            Width="100"/>
                        <DataGridTextColumn Header="Ancienneté"
                            Binding="{Binding Anciennete, StringFormat='{}{0} an(s)'}"
                            Width="80"/>

                        <DataGridTemplateColumn Header="Actions" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏ Modifier"
                                                FontSize="11" Padding="6 2" Margin="0 0 6 0"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Foreground="{StaticResource PrimaryBrush}"
                                                BorderBrush="{StaticResource PrimaryBrush}"
                                                Command="{Binding DataContext.ModifierEmployeCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                        <Button Content="🗑"
                                                FontSize="11" Padding="6 2"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Foreground="Red" BorderBrush="Red"
                                                Click="BtnSupprimerEmploye_Click"
                                                CommandParameter="{Binding}"/>

                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Liste employés supprimés -->
        <Border Background="White" CornerRadius="10" Padding="16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background"   Value="White"/>
                    <Setter Property="CornerRadius" Value="10"/>
                    <Setter Property="Padding"      Value="16"/>
                    <Setter Property="Visibility"   Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AfficherHistorique}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="🗂 Employés supprimés (archivés)"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           Margin="0 0 0 12"/>

                <DataGrid ItemsSource="{Binding Supprimes}"
                          SelectedItem="{Binding EmployeSelectionne}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="120"/>
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Poste" Binding="{Binding Poste.Nom}" Width="140"/>
                        <DataGridTextColumn Header="Supprimé le"
                            Binding="{Binding SupprimeLe, StringFormat='{}{0:dd/MM/yyyy}'}" Width="110"/>
                        <DataGridTemplateColumn Header="Action" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="♻ Restaurer"
                                            FontSize="11" Padding="6 2"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="#1D9E75" BorderBrush="#1D9E75"
                                            Command="{Binding DataContext.RestaurerCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

    </DockPanel>
</UserControl>
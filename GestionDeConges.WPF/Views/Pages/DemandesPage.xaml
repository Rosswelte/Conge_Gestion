<UserControl x:Class="GestionDeConges.WPF.Views.Pages.DemandesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:GestionDeConges.WPF.Converters"
             Background="{StaticResource BgPageBrush}">

   
    <DockPanel Margin="24">

        <!-- En-tête -->
        <StackPanel DockPanel.Dock="Top" Margin="0 0 0 16">
            <TextBlock Text="📋 Demandes de congé"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <Button Content="🔄  Actualiser"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Left"
                    Height="36" Padding="12 0" Margin="0 12 0 0"
                    Command="{Binding ChargerCommand}"/>
        </StackPanel>

        <!-- Spinner -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True" Height="4" Margin="0 0 0 8"
                     Visibility="{Binding IsBusy,
                         Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Messages -->
        <Border DockPanel.Dock="Top"
                Background="#EAF3DE" CornerRadius="6" Padding="12 8" Margin="0 0 0 8"
                Visibility="{Binding Succes,
                    Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding Succes}" Foreground="#27500A"/>
        </Border>
        <Border DockPanel.Dock="Top"
                Background="#FCEBEB" CornerRadius="6" Padding="12 8" Margin="0 0 0 12"
                Visibility="{Binding Erreur,
                    Converter={StaticResource StringToVisibilityConverter}}">
            <TextBlock Text="{Binding Erreur}" Foreground="#501313"/>
        </Border>

        <!-- Panel actions (visible quand une demande est sélectionnée) -->
        <Border DockPanel.Dock="Bottom"
                Background="White" CornerRadius="10" Padding="16" Margin="0 12 0 0"
                BorderBrush="{StaticResource MaterialDesignDivider}" BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DemandeSelectionnee}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Demande sélectionnée"
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock FontSize="14" FontWeight="Bold" Margin="0 4 0 0">
                        <Run Text="{Binding DemandeSelectionnee.Employe.NomComplet, FallbackValue=''}"/>
                        <Run Text=" — "/>
                        <Run Text="{Binding DemandeSelectionnee.TypeConge.Libelle, FallbackValue=''}"/>
                        <Run Text=" ("/>
                        <Run Text="{Binding DemandeSelectionnee.NbJours, FallbackValue=''}"/>
                        <Run Text=" j)"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="✅  Approuver"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="36" Margin="0 0 8 0"
                            Command="{Binding ApprouverCommand}"/>
                    <Button Content="❌  Refuser"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="36" Foreground="Red" BorderBrush="Red"
                            Margin="0 0 8 0"
                            Click="BtnRefuser_Click"/>
                    <Button Content="🗑  Supprimer"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="36" Foreground="Gray" BorderBrush="Gray"
                            Command="{Binding SupprimerCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Liste des demandes -->
        <Border Style="{StaticResource CardStyle}">
            <DataGrid ItemsSource="{Binding Demandes}"
                      SelectedItem="{Binding DemandeSelectionnee}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0"
                      SelectionMode="Single">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Employé"
                        Binding="{Binding Employe.NomComplet}" Width="150"/>
                    <DataGridTextColumn Header="Département"
                        Binding="{Binding Employe.Poste.Departement.Nom}" Width="120"/>
                    <DataGridTextColumn Header="Type"
                        Binding="{Binding TypeConge.Libelle}" Width="130"/>
                    <DataGridTextColumn Header="Début"
                        Binding="{Binding DateDebut,
                            Converter={StaticResource DateOnlyToStringConverter}}"
                        Width="90"/>
                    <DataGridTextColumn Header="Fin"
                        Binding="{Binding DateFin,
                            Converter={StaticResource DateOnlyToStringConverter}}"
                        Width="90"/>
                    <DataGridTextColumn Header="Jours"
                        Binding="{Binding NbJours}" Width="60"/>
                    <DataGridTextColumn Header="Soumis le"
                        Binding="{Binding CreeLe, StringFormat='{}{0:dd/MM/yyyy}'}"
                        Width="100"/>

                    <DataGridTemplateColumn Header="Statut" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8 3"
                                        HorizontalAlignment="Center"
                                        Background="{Binding Statut,
                                            Converter={StaticResource StatutToBrushConverter}}">
                                    <TextBlock
                                        Text="{Binding Statut,
                                            Converter={StaticResource StatutToLibelleConverter}}"
                                        Foreground="{Binding Statut,
                                            Converter={StaticResource StatutToForegroundConverter}}"
                                        FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Traité par"
                        Binding="{Binding Admin.NomUtilisateur, FallbackValue='—'}"
                        Width="100"/>
                    <DataGridTextColumn Header="Commentaire"
                        Binding="{Binding CommentaireAdmin, FallbackValue='—'}"
                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>

<Window x:Class="GestionDeConges.WPF.Views.Pages.RefusMotifDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Motif de refus"
        Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPageBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Veuillez saisir le motif du refus :"
                   FontSize="14" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}"
                   Margin="0 0 0 12"/>

        <TextBox Grid.Row="1"
                 x:Name="TxtMotif"
                 materialDesign:HintAssist.Hint="Motif obligatoire…"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Height="70"
                 Margin="0 0 0 16"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Annuler"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="90" Margin="0 0 8 0"
                    Click="BtnAnnuler_Click"/>
            <Button Content="Confirmer"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="110"
                    Click="BtnConfirmer_Click"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="GestionDeConges.WPF.Views.EmployeSpaceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:conv="clr-namespace:GestionDeConges.WPF.Converters"
        Title="Espace Employé — Mes Congés"
        Height="680" Width="950"
        MinHeight="580" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPageBrush}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Topbar ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20 14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="👤 " FontSize="20" Foreground="White"/>
                    <StackPanel>
                        <TextBlock Text="{Binding NomEmploye, StringFormat='Bonjour, {0}'}"
                                   FontSize="16" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Espace Employé — Vos demandes de congé"
                                   FontSize="11" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔄 Actualiser"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="White" BorderBrush="White"
                            Margin="0 0 8 0" Padding="8 4" FontSize="11"
                            Click="BtnActualiser_Click"/>
                    <Button Content="⬅ Déconnexion"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="White" BorderBrush="White"
                            Padding="8 4" FontSize="11"
                            Click="BtnDeconnexion_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Contenu ────────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">

                <!-- Spinner -->
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0 0 0 12"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Messages -->
                <Border Background="#EAF3DE" CornerRadius="6" Padding="12 8" Margin="0 0 0 12"
                        Visibility="{Binding Succes, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding Succes}" Foreground="#27500A"/>
                </Border>
                <Border Background="#FCEBEB" CornerRadius="6" Padding="12 8" Margin="0 0 0 12"
                        Visibility="{Binding Erreur, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding Erreur}" Foreground="#501313"/>
                </Border>

                <!-- ── Grille 2 colonnes ─────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Mes demandes ──────────────────────────────────── -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="📋 Mes demandes de congé"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0 0 0 12"/>

                            <DataGrid ItemsSource="{Binding MesDemandes}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      SelectionMode="Single">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding TypeConge.Libelle}"
                                        Width="*"/>
                                    <DataGridTextColumn Header="Début"
                                        Binding="{Binding DateDebut, Converter={StaticResource DateOnlyToStringConverter}}"
                                        Width="90"/>
                                    <DataGridTextColumn Header="Fin"
                                        Binding="{Binding DateFin, Converter={StaticResource DateOnlyToStringConverter}}"
                                        Width="90"/>
                                    <DataGridTextColumn Header="Jours"
                                        Binding="{Binding NbJours}"
                                        Width="55"/>
                                    <!-- Statut avec couleur -->
                                    <DataGridTemplateColumn Header="Statut" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="6 2"
                                                        Background="{Binding Statut,
                                                            Converter={StaticResource StatutToBrushConverter}}"
                                                        HorizontalAlignment="Center">
                                                    <TextBlock
                                                        Text="{Binding Statut,
                                                            Converter={StaticResource StatutToLibelleConverter}}"
                                                        Foreground="{Binding Statut,
                                                            Converter={StaticResource StatutToForegroundConverter}}"
                                                        FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <!-- Boutons Modifier + Annuler -->
                                    <DataGridTemplateColumn Header="" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="✏ Modifier"
                                                            FontSize="11" Padding="6 2"
                                                            Margin="0 0 4 0"
                                                            Visibility="{Binding EstModifiable,
                                                                Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Command="{Binding DataContext.ModifierDemandeCommand,
                                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                                            Foreground="{StaticResource PrimaryBrush}"
                                                            BorderBrush="{StaticResource PrimaryBrush}"/>
                                                    <Button Content="Annuler"
                                                            FontSize="11" Padding="6 2"
                                                            Visibility="{Binding EstModifiable,
                                                                Converter={StaticResource BoolToVisibilityConverter}}"
                                                            Command="{Binding DataContext.AnnulerDemandeCommand,
                                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                                            Foreground="Red" BorderBrush="Red"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- ── Panneau droit : Solde + Nouvelle demande ────────── -->
                    <StackPanel Grid.Column="2">

                        <!-- Solde de congés -->
                        <Border Style="{StaticResource CardStyle}" Margin="0 0 0 16">
                            <StackPanel>
                                <TextBlock Text="💰 Mes soldes"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0 0 0 10"/>
                                <ItemsControl ItemsSource="{Binding MesSoldes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0 4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding TypeConge.Libelle}"
                                                           FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           FontWeight="Bold" FontSize="12"
                                                           Foreground="{Binding Restant,
                                                               Converter={StaticResource SoldeToColorConverter}}"
                                                           VerticalAlignment="Center">
                                                    <Run Text="{Binding Restant, Mode=OneWay}"/>
                                                    <Run Text="j"/>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Nouvelle demande -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="➕ Nouvelle demande"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           Margin="0 0 0 12"/>

                                <ComboBox ItemsSource="{Binding TypesConges}"
                                          SelectedItem="{Binding TypeSelectionne}"
                                          DisplayMemberPath="Libelle"
                                          materialDesign:HintAssist.Hint="Type de congé"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Margin="0 0 0 10"/>

                                <!-- Solde restant pour le type choisi -->
                                <Border Background="{StaticResource PrimaryLightBrush}"
                                        CornerRadius="6" Padding="8 4" Margin="0 0 0 10"
                                        Visibility="{Binding TypeSelectionne,
                                            Converter={StaticResource StringToVisibilityConverter}}">
                                    <TextBlock FontSize="12"
                                               Foreground="{Binding SoldeRestant,
                                                   Converter={StaticResource SoldeToColorConverter}}">
                                        <Run Text="Solde disponible : "/>
                                        <Run Text="{Binding SoldeRestant, Mode=OneWay}"
                                             FontWeight="Bold"/>
                                        <Run Text=" jour(s)"/>
                                    </TextBlock>
                                </Border>

                                <DatePicker materialDesign:HintAssist.Hint="Date de début"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                            Margin="0 0 0 10"
                                            SelectedDate="{Binding DateDebutDatetime}"/>

                                <DatePicker materialDesign:HintAssist.Hint="Date de fin"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                            Margin="0 0 0 10"
                                            SelectedDate="{Binding DateFinDatetime}"/>

                                <TextBox materialDesign:HintAssist.Hint="Motif (optionnel)"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Motif}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Height="60"
                                         Margin="0 0 0 14"/>

                                <Button Content="✔ Soumettre la demande"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="40"
                                        Command="{Binding SoumettreDemandeCommand}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

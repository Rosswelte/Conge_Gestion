<Window x:Class="GestionDeConges.WPF.Views.Dialogs.ModifierPosteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Modifier un poste"
        Height="360" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPageBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✏️ Modifier le poste"
                   FontSize="18" FontWeight="Bold"
                   Foreground="{StaticResource PrimaryBrush}" Margin="0 0 0 16"/>

        <TextBox Grid.Row="1" x:Name="TxtNom"
                 materialDesign:HintAssist.Hint="Nom du poste *"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 12"/>

        <ComboBox Grid.Row="2" x:Name="CboDepartement"
                  materialDesign:HintAssist.Hint="Département *"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  DisplayMemberPath="Nom" Margin="0 0 0 12"/>

        <TextBox Grid.Row="3" x:Name="TxtNbMin"
                 materialDesign:HintAssist.Hint="Nb min. employés"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Margin="0 0 0 16"/>

        <Border Grid.Row="4" x:Name="PanelErreur"
                Background="#FCEBEB" CornerRadius="6" Padding="12 8"
                Margin="0 0 0 12" Visibility="Collapsed">
            <TextBlock x:Name="TxtErreur" Foreground="#501313" FontSize="12"/>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="90" Margin="0 0 8 0" Click="BtnAnnuler_Click"/>
            <Button Content="✔ Modifier" Style="{StaticResource PrimaryButtonStyle}"
                    Width="110" Click="BtnModifier_Click"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="GestionDeConges.WPF.Views.Dialogs.ModifierEmployeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Modifier un employé"
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPageBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <StackPanel Grid.Row="0" Margin="0 0 0 20">
            <TextBlock Text="✏️ Modifier un employé"
                       FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock x:Name="TxtSousTitre"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0 4 0 0"/>
        </StackPanel>

        <!-- Formulaire -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0 0 0 12">
            <StackPanel>

                <!-- Nom / Prénom -->
                <Grid Margin="0 0 0 14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtNom"
                             materialDesign:HintAssist.Hint="Nom *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <TextBox Grid.Column="2" x:Name="TxtPrenom"
                             materialDesign:HintAssist.Hint="Prénom *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </Grid>

                <!-- Email -->
                <TextBox x:Name="TxtEmail"
                         materialDesign:HintAssist.Hint="Email *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0 0 0 14"/>

                <!-- Téléphone -->
                <TextBox x:Name="TxtTelephone"
                         materialDesign:HintAssist.Hint="Téléphone"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0 0 0 14"/>

                <!-- Sexe -->
                <ComboBox x:Name="CboSexe"
                          materialDesign:HintAssist.Hint="Sexe *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0 0 0 14">
                    <ComboBoxItem Content="M — Masculin" Tag="M"/>
                    <ComboBoxItem Content="F — Féminin"  Tag="F"/>
                    <ComboBoxItem Content="Autre"        Tag="Autre"/>
                </ComboBox>
                <!-- Date naissance -->
                <DatePicker x:Name="DpDateNaissance"
                            materialDesign:HintAssist.Hint="Date de naissance"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0 0 0 14"/>
                <!-- Date embauche -->
                <DatePicker x:Name="DpDateEmbauche"
                            materialDesign:HintAssist.Hint="Date d'embauche *"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0 0 0 14"/>

                <!-- Poste -->
                <ComboBox x:Name="CboPoste"
                          materialDesign:HintAssist.Hint="Poste *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Nom"
                          Margin="0 0 0 4"/>

            </StackPanel>
        </ScrollViewer>

        <!-- Message d'erreur -->
        <Border Grid.Row="2" x:Name="PanelErreur"
                Background="#FCEBEB" CornerRadius="6" Padding="12 8"
                Margin="0 0 0 8" Visibility="Collapsed">
            <TextBlock x:Name="TxtErreur" Foreground="#501313"
                       TextWrapping="Wrap" FontSize="12"/>
        </Border>

        <!-- Spinner -->
        <ProgressBar Grid.Row="3" x:Name="Spinner"
                     IsIndeterminate="True" Height="3" Margin="0 0 0 14"
                     Visibility="Collapsed"/>

        <!-- Boutons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="100" Margin="0 0 10 0"
                    Click="BtnAnnuler_Click"/>
            <Button x:Name="BtnModifier" Content="✔  Modifier"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="130" Click="BtnModifier_Click"/>
        </StackPanel>
    </Grid>
</Window>
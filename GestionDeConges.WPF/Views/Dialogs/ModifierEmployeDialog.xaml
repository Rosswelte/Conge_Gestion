<Window x:Class="GestionDeConges.WPF.Views.Dialogs.ModifierEmployeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Modifier un employé"
        Height="580" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPageBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <StackPanel Grid.Row="0" Margin="0 0 0 16">
            <TextBlock Text="✏️ Modifier un employé" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock x:Name="TxtSousTitre" FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0 4 0 0"/>
        </StackPanel>

        <!-- Formulaire -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0 0 0 14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtNom"
                             materialDesign:HintAssist.Hint="Nom *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <TextBox Grid.Column="2" x:Name="TxtPrenom"
                             materialDesign:HintAssist.Hint="Prénom *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </Grid>
                <TextBox x:Name="TxtEmail" Margin="0 0 0 14"
                         materialDesign:HintAssist.Hint="Email *"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <TextBox x:Name="TxtTelephone" Margin="0 0 0 14"
                         materialDesign:HintAssist.Hint="Téléphone"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                <ComboBox x:Name="CboSexe" Margin="0 0 0 14"
                          materialDesign:HintAssist.Hint="Sexe *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}">
                    <ComboBoxItem Content="M — Masculin" Tag="M"/>
                    <ComboBoxItem Content="F — Féminin" Tag="F"/>
                    <ComboBoxItem Content="Autre" Tag="Autre"/>
                </ComboBox>
                <DatePicker x:Name="DpDateNaissance" Margin="0 0 0 14"
                            materialDesign:HintAssist.Hint="Date de naissance"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                <DatePicker x:Name="DpDateEmbauche" Margin="0 0 0 14"
                            materialDesign:HintAssist.Hint="Date d'embauche *"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                <ComboBox x:Name="CboPoste"
                          materialDesign:HintAssist.Hint="Poste *"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          DisplayMemberPath="Nom"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Erreur -->
        <Border Grid.Row="2" x:Name="PanelErreur" Background="#FCEBEB"
                CornerRadius="6" Padding="12 8" Margin="0 8 0 8"
                Visibility="Collapsed">
            <TextBlock x:Name="TxtErreur" Foreground="#501313" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Boutons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 8 0 0">
            <Button Content="Annuler" Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="100" Margin="0 0 10 0" Click="BtnAnnuler_Click"/>
            <Button x:Name="BtnModifier" Content="✔  Modifier"
                    Style="{StaticResource PrimaryButtonStyle}" Width="130"
                    Click="BtnModifier_Click"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="GestionDeConges.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:GestionDeConges.WPF.ViewModels"
        xmlns:pages="clr-namespace:GestionDeConges.WPF.Views.Pages"
        Title="Gestion des Congés — Administration"
        Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPageBrush}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <!--
            ╔══════════════════════════════════════════════════════════════╗
            ║  DataTemplates — Associe chaque ViewModel à sa View (Page)  ║
            ║  Le ContentControl de la zone principale résout ces         ║
            ║  templates automatiquement selon le type de PageActive.     ║
            ╚══════════════════════════════════════════════════════════════╝
        -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardPage/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DemandesViewModel}">
            <pages:DemandesPage/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EmployesViewModel}">
            <pages:EmployesPage/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PostesViewModel}">
            <pages:PostesPage/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:HistoriqueViewModel}">
            <pages:HistoriquePage/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             SIDEBAR
        ════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16 24 16 24">
                    <TextBlock Text="🏢 Congés RH"
                               FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding NomAdmin, StringFormat='Admin : {0}'}"
                               FontSize="11" Foreground="#CCFFFFFF"
                               Margin="0 4 0 0"/>
                </StackPanel>

                <!-- Déconnexion (bas) -->
                <Button DockPanel.Dock="Bottom"
                        Content="⬅  Se déconnecter"
                        Style="{StaticResource SidebarButtonStyle}"
                        Margin="8 0 8 16"
                        Command="{Binding SeDeconnecterCommand}"
                        Click="BtnDeconnexion_Click"/>

                <!-- Navigation -->
                <StackPanel Margin="8 0">
                    <Button Content="📊  Tableau de bord"
                            Style="{StaticResource SidebarButtonStyle}"
                            Margin="0 2"
                            Command="{Binding NaviguerDashboardCommand}"/>
                    <Button Content="📋  Demandes"
                            Style="{StaticResource SidebarButtonStyle}"
                            Margin="0 2"
                            Command="{Binding NaviguerDemandesCommand}"/>
                    <Button Content="👥  Employés"
                            Style="{StaticResource SidebarButtonStyle}"
                            Margin="0 2"
                            Command="{Binding NaviguerEmployesCommand}"/>
                    <Button Content="🏢  Postes"
                            Style="{StaticResource SidebarButtonStyle}"
                            Margin="0 2"
                            Command="{Binding NaviguerPostesCommand}"/>
                    <Separator Background="#33FFFFFF" Margin="8 12"/>
                    <Button Content="🗂  Historique"
                            Style="{StaticResource SidebarButtonStyle}"
                            Margin="0 2"
                            Command="{Binding NaviguerHistoriqueCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             CONTENU PRINCIPAL
        ════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Barre de statut -->
            <Border Grid.Row="0" Background="White" Padding="16 10"
                    BorderThickness="0 0 0 1"
                    BorderBrush="{StaticResource MaterialDesignDivider}">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="12"/>
            </Border>

            <!--
                Zone de navigation.
                Le ContentControl utilise les DataTemplates déclarés
                en Window.Resources pour afficher la bonne page
                en fonction du type de PageActive (ViewModel).
            -->
            <ContentControl Grid.Row="1"
                            x:Name="PageContent"
                            Content="{Binding PageActive}"
                            Margin="0"/>
        </Grid>
    </Grid>
</Window>

<Application x:Class="GestionDeConges.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:GestionDeConges.WPF.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Teal"
                    SecondaryColor="Green" />

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />

                <ResourceDictionary>
                    <Color x:Key="PrimaryGreen">#1D9E75</Color>
                    <Color x:Key="PrimaryDark">#0F6E56</Color>
                    <Color x:Key="PrimaryLight">#E1F5EE</Color>
                    <Color x:Key="BgPage">#F5F8F7</Color>
                    <Color x:Key="TextMuted">#6E7D79</Color>

                    <SolidColorBrush x:Key="PrimaryBrush" Color="#1D9E75" />
                    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0F6E56" />
                    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#E1F5EE" />
                    <SolidColorBrush x:Key="BgPageBrush" Color="#F5F8F7" />
                    <SolidColorBrush x:Key="TextMutedBrush" Color="#6E7D79" />

                    <SolidColorBrush x:Key="ApprovedBrush" Color="#EAF3DE" />
                    <SolidColorBrush x:Key="PendingBrush" Color="#FAEEDA" />
                    <SolidColorBrush x:Key="RejectedBrush" Color="#FCEBEB" />
                    <SolidColorBrush x:Key="ApprovedFgBrush" Color="#27500A" />
                    <SolidColorBrush x:Key="PendingFgBrush" Color="#633806" />
                    <SolidColorBrush x:Key="RejectedFgBrush" Color="#501313" />

                    <Style x:Key="CardStyle" TargetType="Border">
                        <Setter Property="Background" Value="White" />
                        <Setter Property="CornerRadius" Value="10" />
                        <Setter Property="Padding" Value="16" />
                    </Style>

                    <Style x:Key="SidebarButtonStyle" TargetType="Button"
                           BasedOn="{StaticResource MaterialDesignFlatButton}">
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                        <Setter Property="Height" Value="48" />
                        <Setter Property="Padding" Value="16 0" />
                        <Setter Property="FontSize" Value="14" />
                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
                    </Style>

                    <Style x:Key="PrimaryButtonStyle" TargetType="Button"
                           BasedOn="{StaticResource MaterialDesignRaisedButton}">
                        <Setter Property="Background" Value="#1D9E75" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
                    </Style>

                    <Style x:Key="StatutChipStyle" TargetType="Border">
                        <Setter Property="CornerRadius" Value="12" />
                        <Setter Property="Padding" Value="8 3" />
                    </Style>

                    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
                    <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
                    <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
                    <converters:StatutToBrushConverter x:Key="StatutToBrushConverter" />
                    <converters:StatutToForegroundConverter x:Key="StatutToForegroundConverter" />
                    <converters:StatutToLibelleConverter x:Key="StatutToLibelleConverter" />
                    <converters:EstModifiableToVisibilityConverter x:Key="EstModifiableToVisibilityConverter" />
                    <converters:DateOnlyToStringConverter x:Key="DateOnlyToStringConverter" />
                    <converters:SoldeToColorConverter x:Key="SoldeToColorConverter" />

                </ResourceDictionary>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>